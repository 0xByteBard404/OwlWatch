# ===========================================
# OwlWatch 舆情监控系统 - 生产环境配置示例
# ===========================================
# 复制此文件为 .env.production 并修改配置
# 重要： 请务必在生产环境部署前修改所有敏感配置！# ===========================================

# ==================== 必填配置 ====================
# 数据库连接 (必填)
DATABASE_URL=postgresql://owlwatch:your_secure_password@postgres:5432/owlwatch

# Redis 连接 (必填)
REDIS_URL=redis://redis:6379/0

# JWT 密钥 (必填)
# 生成安全密钥: openssl rand -hex 32
# 或: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# 初始管理员密码 (必填)
INITIAL_ADMIN_PASSWORD=ChangeMeTo_SomethingSecure

# 默认租户配置
DEFAULT_TENANT_ID=default-tenant
DEFAULT_TENANT_NAME=Default Tenant

# ==================== API 密钥 (可选) ====================
# 至少配置一个搜索 API 以启用数据采集功能
BOCHA_API_KEY=
TAVILY_API_KEY=
ANSPIRE_API_KEY=
BAILIAN_API_KEY=

# ==================== 初始管理员配置 ====================
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@owlwatch.local

# ==================== CORS 配置 ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==================== RSS/RSSHub 配置 ====================
RSSHUB_URL=http://rsshub:1200
