# ===========================================
# OwlWatch 舆情监控系统 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入真实值
# 本文件同时用于：本地开发 / Docker 部署
# ===========================================

# ==================== 必填配置 ====================
# 这些配置必须在启动前设置，否则应用将无法启动

# 数据库连接 (必填)
# PostgreSQL 格式: postgresql://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql://owlwatch:your_secure_password_here@localhost:5432/owlwatch

# Redis 连接 (必填)
REDIS_URL=redis://localhost:6379/0

# JWT 密钥 (必填)
# 生成安全密钥: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# 初始管理员密码 (必填)
# 首次部署时使用，至少8个字符
INITIAL_ADMIN_PASSWORD=

# ==================== 数据库配置 ====================
# Docker Compose 会自动设置这些值
POSTGRES_USER=owlwatch
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=owlwatch

# ==================== API 密钥 (可选) ====================
# 至少配置一个搜索 API 以启用数据采集功能

# 博查搜索 API (国内搜索)
BOCHA_API_KEY=

# Tavily 搜索 API (海外搜索)
TAVILY_API_KEY=

# Anspire 深度爬取 API
ANSPIRE_API_KEY=

# 百炼 AI 平台 (摘要/趋势分析，可选)
BAILIAN_API_KEY=

# ==================== 应用配置 ====================
# 环境：development / production
APP_ENV=development
DEBUG=true

# ==================== 初始管理员配置 ====================
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_EMAIL=admin@owlwatch.local

# ==================== 默认租户配置 ====================
DEFAULT_TENANT_ID=default-tenant
DEFAULT_TENANT_NAME=Default Tenant

# ==================== CORS 配置 ====================
# 允许的前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ==================== RSS/RSSHub 配置 ====================
# RSSHub 实例地址，可以使用公共实例或自建
RSSHUB_URL=https://rsshub.app

# ==================== 通知配置 (可选) ====================
# Webhook 通知
ALERT_WEBHOOK_URL=

# 企业微信 Webhook
WECHAT_WEBHOOK_URL=

# 短信通知
SMS_ACCESS_KEY=

# 邮件通知
EMAIL_SMTP_HOST=
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=

# ==================== 预警配置 ====================
# 负面情感阈值
ALERT_NEGATIVE_THRESHOLD=0.3
# 讨论量阈值
ALERT_VOLUME_THRESHOLD=200

# ==================== 负面关键词配置 ====================
# 用于负面舆情搜索，逗号分隔
NEGATIVE_KEYWORDS=违规,违法,投诉,通报,处罚,曝光,被查,立案,调查,维权

# ==================== 调度配置 ====================
# 采集间隔（秒）
COLLECT_INTERVAL_HIGH=300
COLLECT_INTERVAL_MEDIUM=900
COLLECT_INTERVAL_LOW=1800
