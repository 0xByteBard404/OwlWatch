# ===========================================
# OwlWatch 舆情监控系统 - 环境变量配置
# ===========================================
# 复制此文件为 .env 并填入真实值
# 本文件同时用于：本地开发 / Docker 部署
# ===========================================

# ========== 数据库配置 ==========
# PostgreSQL（本地开发用 localhost，Docker 部署用 postgres）
POSTGRES_USER=owlwatch
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=owlwatch
DATABASE_URL=postgresql://owlwatch:your_secure_password_here@localhost:5432/owlwatch

# Redis（本地开发用 localhost，Docker 部署用 redis）
REDIS_URL=redis://localhost:6379/0

# ========== API 密钥（至少配置一个搜索 API）==========
# 博查搜索 API
BOCHA_API_KEY=your_bocha_api_key
# Tavily 搜索 API
TAVILY_API_KEY=your_tavily_api_key
# Anspire 深度爬取 API
ANSPIRE_API_KEY=your_anspire_api_key
# 百炼 AI 平台（情感分析）
BAILIAN_API_KEY=your_bailian_api_key

# ========== JWT 配置 ==========
JWT_SECRET=your_jwt_secret_key_here_at_least_32_chars
JWT_ALGORITHM=HS256

# ========== 应用配置 ==========
# 环境：development / production
APP_ENV=development
DEBUG=true
# 禁用定时任务调度器（测试环境设为 true）
DISABLE_SCHEDULER=false
